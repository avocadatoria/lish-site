# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_ENV="localdev-yourname"
APP_URL="https://lish-dev-www.avocadatoria.com"
API_PORT="3002"
API_URL="http://localhost:3002"
LOG_LEVEL="debug"

# Non-production email subject prefix (must be non-empty outside production)
NONPROD_EMAIL_SUBJECT_PREFIX="[localdev]"
ENABLE_MAIL="false"

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_SES_FROM_EMAIL="LISH <avocado876@gmail.com>"

# ─────────────────────────────────────────────
# Strapi (primary CMS) — Strapi's own config is in cms/strapi/.env
# ─────────────────────────────────────────────
STRAPI_URL="http://localhost:1337"
STRAPI_API_TOKEN="create-in-strapi-admin-panel"
SSR_REVALIDATE_SECS="10"
SNIPPET_CACHE_TTL_SECS="10"
PREVIEW_SECRET="generate-with-node -e console.log(require('crypto').randomBytes(32).toString('base64'))"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_SECS="60"
CORS_ORIGIN="*"
CMS_URL="https://your-cms-domain.example.com"

# ─────────────────────────────────────────────
# Contact Form
# ─────────────────────────────────────────────
CONTACT_US_RECIPIENT="avocado876@gmail.com"
