# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_ENV="localdev-yourname"
APP_URL="https://frp-1.avocadatoria.com"
API_PORT="3002"
API_URL="http://localhost:3002"
LOG_LEVEL="debug"

# Non-production email subject prefix (must be non-empty outside production)
NONPROD_EMAIL_SUBJECT_PREFIX="[localdev]"
ENABLE_MAIL="false"

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="lish_dev"
DB_USER="postgres"
DB_PASSWORD="postgres"

# ─────────────────────────────────────────────
# Auth0
# ─────────────────────────────────────────────
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID="your-client-id"
AUTH0_CLIENT_SECRET="your-client-secret"
AUTH0_CALLBACK_URL="https://frp-1.avocadatoria.com/api/auth/callback"
AUTH0_DB_CONNECTION="Username-Password-Authentication"

# iron-session
SESSION_SECRET="a-random-string-at-least-32-characters-long-here"

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="your-bucket-name"
AWS_CLOUDFRONT_DOMAIN="your-cloudfront-domain.cloudfront.net"
AWS_CLOUDFRONT_KEY_PAIR_ID="your-key-pair-id"
AWS_CLOUDFRONT_PRIVATE_KEY="your-private-key"
AWS_SES_FROM_EMAIL="LISH <avocado876@gmail.com>"
AWS_MEDIACONVERT_ENDPOINT="https://your-endpoint.mediaconvert.us-east-1.amazonaws.com"
AWS_MEDIACONVERT_ROLE="arn:aws:iam::role/MediaConvertRole"

# ─────────────────────────────────────────────
# Anthropic AI
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─────────────────────────────────────────────
# Google Calendar
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="https://frp-1.avocadatoria.com/api/calendar/callback"

# ─────────────────────────────────────────────
# Zoom
# ─────────────────────────────────────────────
ZOOM_ACCOUNT_ID="your-zoom-account-id"
ZOOM_CLIENT_ID="your-zoom-client-id"
ZOOM_CLIENT_SECRET="your-zoom-client-secret"

# ─────────────────────────────────────────────
# Strapi (primary CMS) — Strapi's own config is in cms/strapi/.env
# ─────────────────────────────────────────────
STRAPI_URL="http://localhost:1337"
STRAPI_API_TOKEN="create-in-strapi-admin-panel"

# ─────────────────────────────────────────────
# WordPress (secondary CMS)
# ─────────────────────────────────────────────
WORDPRESS_API_URL="https://your-wordpress-site.com/wp-json/wp/v2"

# ─────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────
REQUIRE_EMAIL_VERIFICATION="false"

# ─────────────────────────────────────────────
# Contact Form
# ─────────────────────────────────────────────
CONTACT_US_RECIPIENT="avocado876@gmail.com"

# ─────────────────────────────────────────────
# MUI X Pro License
# ─────────────────────────────────────────────
NEXT_PUBLIC_MUI_LICENSE_KEY="your-license-key"
