{
  "name": "scaffold-master",
  "version": "1.0.0",
  "description": "Kitchen-sink template webapp — subtract features per client project",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "preinstall": "pnpx only-allow pnpm",
    "predev": "lsof -ti :3000 | xargs kill -9 2>/dev/null; lsof -ti :3001 | xargs kill -9 2>/dev/null; lsof -ti :3002 | xargs kill -9 2>/dev/null; lsof -ti :1337 | xargs kill -9 2>/dev/null; lsof -ti :3004 | xargs kill -9 2>/dev/null; pkill frpc 2>/dev/null; echo 'Ports 3000-3002, 1337, 3004 cleared, frpc killed'",
    "dev:nginx": "nginx -g 'daemon off;'",
    "dev:frpc": "frpc -c /usr/local/etc/frp/frpc.toml",
    "dev:next": "next dev -p 3001",
    "dev:api": "node --watch server/index.js",
    "dev:strapi": "cd cms/strapi && pnpm exec strapi develop --no-watch-admin",
    "dev": "concurrently --kill-others -n next,api,strapi,nginx,frpc -c blue,green,cyan,magenta,yellow \"pnpm dev:next\" \"pnpm dev:api\" \"pnpm dev:strapi\" \"pnpm dev:nginx\" \"pnpm dev:frpc\"",
    "build": "next build",
    "start:next": "next start -p 3001",
    "start:api": "node server/index.js",
    "start:strapi": "cd cms/strapi && pnpm exec strapi start",
    "build:strapi": "cd cms/strapi && pnpm exec strapi build",
    "install:strapi": "cd cms/strapi && pnpm install",
    "start": "concurrently -n next,api,strapi -c blue,green,cyan \"pnpm start:next\" \"pnpm start:api\" \"pnpm start:strapi\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "echo 'E2E tests not yet implemented. Needs vitest.e2e.config.js + Playwright or API integration setup.' && exit 1",
    "db:migrate": "pnpm exec sequelize-cli db:migrate",
    "db:migrate:undo": "pnpm exec sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "pnpm exec sequelize-cli db:migrate:undo:all",
    "db:seed": "pnpm exec sequelize-cli db:seed:all",
    "db:seed:undo": "pnpm exec sequelize-cli db:seed:undo:all",
    "db:migration:create": "pnpm exec sequelize-cli migration:generate --name",
    "job:cleanup-expired-invitations": "node server/jobs/cleanup-expired-invitations.js"
  },
  "dependencies-comments": "We pin all dep versions (no ~ or ^, etc.); avoids last-minute breaks; then, we upgrade periodically and test extensively",
  "dependencies": {
    "@ai-sdk/anthropic": "1.2.12",
    "@ai-sdk/react": "3.0.107",
    "@anthropic-ai/sdk": "0.78.0",
    "@aws-sdk/client-mediaconvert": "3.958.0",
    "@aws-sdk/client-s3": "3.998.0",
    "@aws-sdk/client-ses": "3.996.0",
    "@aws-sdk/client-sns": "3.968.0",
    "@aws-sdk/cloudfront-signer": "3.993.0",
    "@aws-sdk/s3-request-presigner": "3.997.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fastify/cors": "11.2.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/websocket": "11.2.0",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "@mui/x-date-pickers": "8.27.2",
    "@mui/x-date-pickers-pro": "8.27.2",
    "@mui/x-license": "8.26.0",
    "@tiptap/react": "3.20.0",
    "@tiptap/starter-kit": "3.20.0",
    "ai": "5.0.52",
    "concurrently": "9.2.1",
    "csv-stringify": "6.6.0",
    "dayjs": "1.11.19",
    "dotenv": "17.3.1",
    "fastify": "5.7.4",
    "fastify-plugin": "5.1.0",
    "googleapis": "171.4.0",
    "iron-session": "8.0.4",
    "next": "15.5.10",
    "openid-client": "6.8.2",
    "pg": "8.19.0",
    "pg-hstore": "2.3.4",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "puppeteer": "24.37.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-draggable": "4.5.0",
    "react-hook-form": "7.71.0",
    "sass": "1.97.3",
    "sequelize": "6.37.7",
    "stripe": "20.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@next/eslint-plugin-next": "15.5.12",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.3",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "15.15.0",
    "jsdom": "25.0.1",
    "sequelize-cli": "6.6.5",
    "supertest": "7.2.2",
    "vitest": "3.2.4"
  }
}
