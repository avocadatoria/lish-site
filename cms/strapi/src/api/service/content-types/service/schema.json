{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "DefaultLabel": {
      "type": "string",
      "required": true
    },
    "NavLabel": {
      "type": "string"
    },
    "ProvidersPageLabel": {
      "type": "string"
    },
    "HomepageLabel": {
      "type": "string"
    },
    "ServicePageContent": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "ServicePageTagline": {
      "type": "string"
    },
    "CreatePage": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "URLSlug": {
      "type": "uid",
      "targetField": "DefaultLabel",
      "required": true
    },
    "PeopleList": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::people-list.people-list"
    },
    "InternalNotes": {
      "type": "text",
      "private": true
    },
    "services_lists": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::services-list.services-list",
      "inversedBy": "Services"
    }
  }
}
